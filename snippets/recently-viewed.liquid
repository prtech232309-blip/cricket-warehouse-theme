{%- comment -%}
  Usage: {% render 'recently-viewed', current_product: product %}
  Reads product handles from localStorage and renders them via JS.
{%- endcomment -%}

<div class="recently-viewed" id="RecentlyViewed" style="display:none;">
  <h2 class="recently-viewed__title">Recently Viewed</h2>
  <div class="recently-viewed__grid" id="RecentlyViewedGrid"></div>
</div>

<script>
(function () {
  try {
    const key = 'cwa_recently_viewed';
    const currentId = {{ current_product.id | json }};
    const stored = JSON.parse(localStorage.getItem(key) || '[]');
    const filtered = stored.filter(p => p.id !== currentId).slice(0, 6);

    if (filtered.length === 0) return;

    const container = document.getElementById('RecentlyViewedGrid');
    const wrapper = document.getElementById('RecentlyViewed');
    if (!container || !wrapper) return;

    const fmt = (c) => '$' + (c / 100).toFixed(2);

    container.innerHTML = filtered.map(p => `
      <a href="/products/${p.handle}" style="display:block;text-decoration:none;border:1px solid var(--color-outline-variant);padding:12px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-deep-navy)'" onmouseout="this.style.borderColor='var(--color-outline-variant)'">
        ${p.image ? `<img src="${p.image.src || p.image}" alt="${p.title}" style="width:100%;aspect-ratio:1;object-fit:cover;margin-bottom:10px;" loading="lazy">` : `<div style="width:100%;aspect-ratio:1;background:var(--color-pitch-gray);margin-bottom:10px;"></div>`}
        <div style="font-family:var(--font-heading);font-size:14px;font-weight:700;color:var(--color-deep-navy);text-transform:uppercase;margin-bottom:4px;line-height:1.3;">${p.title}</div>
        <div style="font-family:var(--font-heading);font-size:15px;font-weight:700;color:var(--color-sport-red);">${fmt(p.price)}</div>
      </a>`).join('');

    wrapper.style.display = '';
  } catch {}
})();
</script>
