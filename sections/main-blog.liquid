<div class="blog-page">

  <div class="blog-page__header">
    <span class="blog-page__eyebrow">{{ section.settings.eyebrow | default: 'THE PITCH' }}</span>
    <h1 class="blog-page__title">{{ blog.title | upcase | default: 'CRICKET INSIGHTS' }}</h1>
  </div>

  {%- if blog.articles.size > 0 -%}
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <article class="blog-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="blog-card__image" tabindex="-1" aria-hidden="true">
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag: loading: 'lazy', alt: article.image.alt | default: article.title | escape
                }}
              </a>
            {%- else -%}
              <div class="blog-card__image" style="background:var(--color-pitch-gray);display:flex;align-items:center;justify-content:center;">
                <span class="material-symbols-outlined" style="font-size:48px;color:var(--color-outline-variant);" aria-hidden="true">sports_cricket</span>
              </div>
            {%- endif -%}

            <div class="blog-card__content">
              {%- if article.tags.size > 0 -%}
                <span class="blog-card__tag">{{ article.tags.first }}</span>
              {%- endif -%}
              <h2 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>
              {%- if article.excerpt != blank -%}
                <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
              {%- elsif article.content != blank -%}
                <p class="blog-card__excerpt">{{ article.content | strip_html | truncate: 140 }}</p>
              {%- endif -%}
              <div class="blog-card__meta">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                {%- if article.author != blank -%}
                  <span class="blog-card__meta-sep">·</span>
                  <span>{{ article.author }}</span>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="collection-pagination" style="margin-top:48px;" aria-label="Blog pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" aria-label="Previous page">
              <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
            </a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span{% if part.title == paginate.current_page %} class="current" aria-current="page"{% endif %}>{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" aria-label="Next page">
              <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  {%- else -%}
    <div class="blog-empty">
      <span class="material-symbols-outlined" aria-hidden="true">sports_cricket</span>
      <p>No articles published yet. Check back soon!</p>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Blog Page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "THE PITCH"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 9
    }
  ]
}
{% endschema %}
