<div class="article-page">

  <a class="article-page__back" href="{{ blog.url }}">
    <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true">arrow_back</span>
    Back to {{ blog.title }}
  </a>

  {%- if article.tags.size > 0 -%}
    <span class="article-page__tag">{{ article.tags.first }}</span>
  {%- endif -%}

  <h1 class="article-page__title">{{ article.title }}</h1>

  <div class="article-page__meta">
    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
      {{ article.published_at | date: '%B %d, %Y' }}
    </time>
    {%- if article.author != blank -%}
      <span>·</span>
      <span>By {{ article.author }}</span>
    {%- endif -%}
    {%- if article.comments_count > 0 -%}
      <span>·</span>
      <a href="#ArticleComments" style="color:inherit;text-decoration:none;">{{ article.comments_count }} comment{{ article.comments_count | pluralize: '', 's' }}</a>
    {%- endif -%}
  </div>

  {%- if article.image -%}
    <div class="article-page__image">
      {{
        article.image
        | image_url: width: 1200
        | image_tag: loading: 'eager', fetchpriority: 'high', alt: article.image.alt | default: article.title | escape
      }}
    </div>
  {%- endif -%}

  <div class="article-page__body">
    {{ article.content }}
  </div>

  <!-- Tags -->
  {%- if article.tags.size > 0 -%}
    <div style="margin-top:40px;padding-top:24px;border-top:1px solid var(--color-pitch-gray);display:flex;gap:8px;flex-wrap:wrap;">
      {%- for tag in article.tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}" style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;padding:4px 12px;border:1px solid var(--color-outline-variant);color:var(--color-deep-navy);text-decoration:none;">{{ tag }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Comments -->
  {%- if blog.comments_enabled? -%}
    <div id="ArticleComments" style="margin-top:64px;">
      <h2 style="font-family:var(--font-heading);font-size:24px;font-weight:700;color:var(--color-deep-navy);text-transform:uppercase;margin-bottom:32px;">
        Comments ({{ article.comments_count }})
      </h2>

      {%- if article.comments.size > 0 -%}
        {%- for comment in article.comments -%}
          <div style="padding:24px;border:1px solid var(--color-pitch-gray);margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:12px;">
              <strong style="color:var(--color-deep-navy);">{{ comment.author }}</strong>
              <time style="font-family:var(--font-mono);font-size:11px;color:var(--color-outline);">{{ comment.created_at | date: '%B %d, %Y' }}</time>
            </div>
            <p style="color:var(--color-on-surface-variant);line-height:1.7;">{{ comment.content }}</p>
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- form 'new_comment', article -%}
        <h3 style="font-family:var(--font-heading);font-size:20px;font-weight:700;text-transform:uppercase;margin-bottom:24px;color:var(--color-deep-navy);">LEAVE A COMMENT</h3>
        {%- if form.posted_successfully? -%}
          <div class="auth-success">Your comment has been submitted and is awaiting approval. Thank you!</div>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="auth-form__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div class="contact-form__group">
            <label class="contact-form__label" for="CommentAuthor">Name *</label>
            <input class="contact-form__input" type="text" id="CommentAuthor" name="comment[author]" required>
          </div>
          <div class="contact-form__group">
            <label class="contact-form__label" for="CommentEmail">Email *</label>
            <input class="contact-form__input" type="email" id="CommentEmail" name="comment[email]" required>
          </div>
        </div>
        <div class="contact-form__group" style="margin-bottom:16px;">
          <label class="contact-form__label" for="CommentBody">Comment *</label>
          <textarea class="contact-form__textarea" id="CommentBody" name="comment[body]" rows="5" required></textarea>
        </div>
        <button class="contact-form__submit" type="submit">POST COMMENT</button>
      {%- endform -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Article Page",
  "settings": []
}
{% endschema %}
