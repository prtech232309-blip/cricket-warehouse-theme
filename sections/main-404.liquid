<div class="page-404">
  <div class="page-404__code" aria-hidden="true">404</div>
  <span class="material-symbols-outlined page-404__icon" aria-hidden="true">sports_cricket</span>
  <h1 class="page-404__title">{{ section.settings.title | default: 'PAGE NOT FOUND' }}</h1>
  <p class="page-404__desc">{{ section.settings.description | default: "Looks like this page has been stumped. Let's get you back to the crease." }}</p>
  <div class="page-404__actions">
    <a class="btn btn-primary" href="{{ routes.root_url }}" style="font-size:16px;padding:14px 32px;">
      GO HOME
    </a>
    <a class="btn btn-outline" href="{{ routes.collections_url }}" style="font-size:16px;padding:14px 32px;">
      SHOP ALL GEAR
    </a>
  </div>
</div>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "PAGE NOT FOUND"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Looks like this page has been stumped. Let's get you back to the crease."
    }
  ]
}
{% endschema %}
