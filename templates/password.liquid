<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} — Coming Soon</title>
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800;900&family=Inter:wght@400;500&family=JetBrains+Mono:wght@700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet">
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body>
    <div class="password-page">
      <a href="{{ routes.root_url }}" class="password-page__logo">
        CRICKET <span>WAREHOUSE</span> USA
      </a>

      <span class="material-symbols-outlined password-page__icon" aria-hidden="true">lock</span>
      <h1 class="password-page__title">COMING<br>SOON</h1>
      <p class="password-page__desc">We're preparing something epic. Enter the password to get a sneak peek, or check back soon.</p>

      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <div class="password-page__error" role="alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="password-page__form">
          <input
            class="password-page__input"
            type="password"
            name="password"
            placeholder="Store password"
            autocomplete="current-password"
            aria-label="Store password"
          >
          <button class="password-page__btn" type="submit">ENTER</button>
        </div>
      {%- endform -%}

      <p class="password-page__admin">
        Are you the store owner? <a href="/admin">Log in here</a>.
      </p>
    </div>
  </body>
</html>
